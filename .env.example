# Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/echo_chat?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# OpenAI API key (required when AI_PROVIDER=openai)
OPENAI_API_KEY="sk-..."

# Groq API key (required when AI_PROVIDER=groq, which is the default)
GROQ_API_KEY="gsk-..."

# AI provider: "groq" | "openai" (defaults to "groq")
AI_PROVIDER="groq"

# Public app URL (used for callbacks and links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
